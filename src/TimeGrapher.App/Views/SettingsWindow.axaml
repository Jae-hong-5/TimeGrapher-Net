<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TimeGrapher.App.Views.SettingsWindow"
        Title="Settings"
        Icon="/Assets/App/AppIcon-256.png"
        Width="420" Height="282"
        CanResize="False"
        SystemDecorations="None"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
  <Border BorderBrush="{DynamicResource ChromeAccentBrush}" BorderThickness="1">
  <Grid RowDefinitions="36,*" Background="{DynamicResource SurfaceBgBrush}">
    <Border Grid.Row="0"
            Background="{DynamicResource SurfaceBgBrush}"
            BorderBrush="{DynamicResource ChromeBorderBrush}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto">
        <Grid Grid.Column="0"
              Background="Transparent"
              PointerPressed="OnTitleBarPointerPressed">
          <TextBlock Text="Settings"
                     VerticalAlignment="Center"
                     Margin="12,0,0,0"
                     FontFamily="{StaticResource TitleFontFamily}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
        </Grid>
        <Button Name="CloseSettingsButton"
                Grid.Column="1"
                Classes="TitleBarIconButton TitleBarCloseButton"
                Click="OnCloseSettingsButtonClick"
                ToolTip.Tip="Close">
          <Viewbox Width="15" Height="15">
            <Path Width="24" Height="24" Stretch="Uniform"
                  Data="M6.4 5L12 10.6L17.6 5L19 6.4L13.4 12L19 17.6L17.6 19L12 13.4L6.4 19L5 17.6L10.6 12L5 6.4L6.4 5Z" />
          </Viewbox>
        </Button>
      </Grid>
    </Border>

    <StackPanel Grid.Row="1"
                Margin="18,14,18,18"
                Spacing="12"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top">
      <TextBlock Text="Run Settings"
                 Classes="SectionHeader"
                 HorizontalAlignment="Left" />
      <CheckBox Name="UseConsetCheckBox"
                Content="C Event Use Onset Timing"
                FontWeight="Bold"
                HorizontalAlignment="Left"
                IsEnabled="{Binding AreRunParametersEnabled}"
                IsChecked="{Binding UseCOnset, Mode=TwoWay}"
                ToolTip.Tip="Time the C event from its onset instead of its peak" />
      <CheckBox Name="PllEventVetoCheckBox"
                Content="PLL Event Veto (impulse rejection)"
                FontWeight="Bold"
                HorizontalAlignment="Left"
                IsEnabled="{Binding AreRunParametersEnabled}"
                IsChecked="{Binding PllEventVeto, Mode=TwoWay}"
                ToolTip.Tip="Reject phase-mismatched impulse events before metrics" />
      <Border Height="1"
              Background="{DynamicResource ChromeBorderBrush}"
              Margin="0,2" />
      <TextBlock Text="Logging"
                 Classes="SectionHeader"
                 HorizontalAlignment="Left" />
      <CheckBox Name="MeasurementLogEnabledCheckBox"
                Content="Save measurement CSV log"
                FontWeight="Bold"
                HorizontalAlignment="Left"
                IsEnabled="{Binding AreRunParametersEnabled}"
                IsChecked="{Binding IsMeasurementLogEnabled, Mode=TwoWay}"
                ToolTip.Tip="Save result rows to the executable log folder" />
    </StackPanel>
  </Grid>
  </Border>
</Window>
