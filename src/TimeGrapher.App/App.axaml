<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TimeGrapher.App.App"
             RequestedThemeVariant="Light">
  <Application.Resources>
    <ResourceDictionary>
      <FontFamily x:Key="AppFontFamily">avares://TimeGrapher.App/Assets/Fonts/D2Coding#D2Coding</FontFamily>
      <FontFamily x:Key="TitleFontFamily">avares://TimeGrapher.App/Assets/Fonts/Hack#Hack</FontFamily>
      <CornerRadius x:Key="ControlCornerRadius">0</CornerRadius>
      <CornerRadius x:Key="OverlayCornerRadius">0</CornerRadius>

      <!--
        Single source of truth for every theme color (UI chrome AND scope graphs).
        Define each color once here; brushes derive from these Color keys, and the
        graph renderer reads the same keys via PlotThemePalette.FromResources.
        To recolor the app, edit only this block.
      -->
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <Color x:Key="SurfaceColor">#E2E3E4</Color>
          <Color x:Key="PanelColor">#E2E3E4</Color>
          <Color x:Key="TextPrimaryColor">#1A1A1A</Color>
          <Color x:Key="TextSecondaryColor">#6E6E6E</Color>
          <Color x:Key="ChromeBorderColor">#CFCFCF</Color>
          <Color x:Key="ChromeAccentColor">#C41230</Color>
          <Color x:Key="ScopeBgColor">#FFFFFF</Color>
          <Color x:Key="ScopeGridColor">#EAEAEA</Color>
          <Color x:Key="TraceWaveColor">#6B6B6B</Color>
          <Color x:Key="TraceTickColor">#2C9118</Color>
          <Color x:Key="TraceTockColor">#D22222</Color>
          <Color x:Key="TraceGhostColor">#A0A0A0</Color>
          <Color x:Key="AveragePeriodAnnotationColor">#9A9A9A</Color>
          <Color x:Key="AveragePeriodAnnotationAlternateColor">#C4C4C4</Color>
          <Color x:Key="VarioAcceptBandColor">#2C9118</Color>
          <Color x:Key="VarioAcceptBandEdgeColor">#2C9118</Color>
          <Color x:Key="VarioMinMaxColor">#2D7DD2</Color>
          <Color x:Key="VarioAverageColor">#C0392B</Color>
          <Color x:Key="VarioGoodColor">#0072B2</Color>
          <Color x:Key="VarioWarnColor">#B06A00</Color>
          <Color x:Key="VarioBadColor">#C03030</Color>

          <SolidColorBrush x:Key="SurfaceBgBrush" Color="{DynamicResource SurfaceColor}" />
          <SolidColorBrush x:Key="PanelBgBrush" Color="{DynamicResource PanelColor}" />
          <SolidColorBrush x:Key="ScopeBgBrush" Color="{DynamicResource ScopeBgColor}" />
          <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
          <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
          <SolidColorBrush x:Key="ChromeBorderBrush" Color="{DynamicResource ChromeBorderColor}" />
          <SolidColorBrush x:Key="ChromeAccentBrush" Color="{DynamicResource ChromeAccentColor}" />
          <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="{DynamicResource ChromeAccentColor}" />
          <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="{DynamicResource ChromeAccentColor}" />
          <SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="{DynamicResource ChromeAccentColor}" />
          <SolidColorBrush x:Key="ToggleSwitchStrokeOn" Color="{DynamicResource ChromeAccentColor}" />
          <SolidColorBrush x:Key="ToggleSwitchStrokeOnPointerOver" Color="{DynamicResource ChromeAccentColor}" />
          <SolidColorBrush x:Key="ToggleSwitchStrokeOnPressed" Color="{DynamicResource ChromeAccentColor}" />
          <SolidColorBrush x:Key="VarioMinMaxBrush" Color="{DynamicResource VarioMinMaxColor}" />
          <SolidColorBrush x:Key="VarioAverageBrush" Color="{DynamicResource VarioAverageColor}" />
          <SolidColorBrush x:Key="VarioGoodBrush" Color="{DynamicResource VarioGoodColor}" />
          <SolidColorBrush x:Key="VarioWarnBrush" Color="{DynamicResource VarioWarnColor}" />
          <SolidColorBrush x:Key="VarioBadBrush" Color="{DynamicResource VarioBadColor}" />

          <!--
            Sapphire-crystal glass layer (UI chrome only; the graphs are untouched).
            AmbientBackdrop is the lit field the glass floats on; GlassPanel is a
            translucent top-lit frost; GlassRim is the crystal bevel - a bright top
            edge fading to the chrome hairline; GlassShadow lifts each pane off the
            backdrop. Edges stay sharp (0px). The glass tones are theme-specific
            literal values defined once per theme block here (not derived from the
            palette Color keys above); the active ThemeDictionary still swaps the
            whole brush on a theme toggle, so the recolor stays one-place per theme.
          -->
          <LinearGradientBrush x:Key="AmbientBackdropBrush" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0" Color="#E8E9EA" />
            <GradientStop Offset="1" Color="#DCDDDE" />
          </LinearGradientBrush>
          <LinearGradientBrush x:Key="GlassPanelBrush" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0" Color="#B0FFFFFF" />
            <GradientStop Offset="1" Color="#8CFFFFFF" />
          </LinearGradientBrush>
          <LinearGradientBrush x:Key="GlassRimBrush" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0" Color="#FFFFFF" />
            <GradientStop Offset="0.5" Color="#DFE0E1" />
            <GradientStop Offset="1" Color="#CFCFCF" />
          </LinearGradientBrush>
          <BoxShadows x:Key="GlassShadow">0 2 10 0 #22000000</BoxShadows>

          <!-- Selected tab text: pure black in light theme. -->
          <SolidColorBrush x:Key="TabItemHeaderForegroundSelected" Color="#000000" />
          <SolidColorBrush x:Key="TabItemHeaderForegroundSelectedPointerOver" Color="#000000" />
          <SolidColorBrush x:Key="TabItemHeaderForegroundSelectedPressed" Color="#000000" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
          <Color x:Key="SurfaceColor">#1D1D1B</Color>
          <Color x:Key="PanelColor">#1D1D1B</Color>
          <Color x:Key="TextPrimaryColor">#C2C8CE</Color>
          <Color x:Key="TextSecondaryColor">#9A9DA1</Color>
          <Color x:Key="ChromeBorderColor">#333333</Color>
          <Color x:Key="ChromeAccentColor">#C24A62</Color>
          <Color x:Key="ScopeBgColor">#000000</Color>
          <Color x:Key="ScopeGridColor">#1A1A1A</Color>
          <Color x:Key="TraceWaveColor">#A0A0A0</Color>
          <Color x:Key="TraceTickColor">#5FDD45</Color>
          <Color x:Key="TraceTockColor">#FF5C5C</Color>
          <Color x:Key="TraceGhostColor">#686868</Color>
          <Color x:Key="AveragePeriodAnnotationColor">#9A9A9A</Color>
          <Color x:Key="AveragePeriodAnnotationAlternateColor">#C4C4C4</Color>
          <Color x:Key="VarioAcceptBandColor">#5FDD45</Color>
          <Color x:Key="VarioAcceptBandEdgeColor">#5FDD45</Color>
          <Color x:Key="VarioMinMaxColor">#2D7DD2</Color>
          <Color x:Key="VarioAverageColor">#FF6B6B</Color>
          <Color x:Key="VarioGoodColor">#0072B2</Color>
          <Color x:Key="VarioWarnColor">#B06A00</Color>
          <Color x:Key="VarioBadColor">#FF6B6B</Color>

          <SolidColorBrush x:Key="SurfaceBgBrush" Color="{DynamicResource SurfaceColor}" />
          <SolidColorBrush x:Key="PanelBgBrush" Color="{DynamicResource PanelColor}" />
          <SolidColorBrush x:Key="ScopeBgBrush" Color="{DynamicResource ScopeBgColor}" />
          <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
          <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
          <SolidColorBrush x:Key="ChromeBorderBrush" Color="{DynamicResource ChromeBorderColor}" />
          <SolidColorBrush x:Key="ChromeAccentBrush" Color="{DynamicResource ChromeAccentColor}" />
          <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="{DynamicResource ChromeAccentColor}" />
          <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="{DynamicResource ChromeAccentColor}" />
          <SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="{DynamicResource ChromeAccentColor}" />
          <SolidColorBrush x:Key="ToggleSwitchStrokeOn" Color="{DynamicResource ChromeAccentColor}" />
          <SolidColorBrush x:Key="ToggleSwitchStrokeOnPointerOver" Color="{DynamicResource ChromeAccentColor}" />
          <SolidColorBrush x:Key="ToggleSwitchStrokeOnPressed" Color="{DynamicResource ChromeAccentColor}" />
          <SolidColorBrush x:Key="VarioMinMaxBrush" Color="{DynamicResource VarioMinMaxColor}" />
          <SolidColorBrush x:Key="VarioAverageBrush" Color="{DynamicResource VarioAverageColor}" />
          <SolidColorBrush x:Key="VarioGoodBrush" Color="{DynamicResource VarioGoodColor}" />
          <SolidColorBrush x:Key="VarioWarnBrush" Color="{DynamicResource VarioWarnColor}" />
          <SolidColorBrush x:Key="VarioBadBrush" Color="{DynamicResource VarioBadColor}" />

          <!-- Sapphire-crystal glass layer - dark variant. See the Light block for the model. -->
          <LinearGradientBrush x:Key="AmbientBackdropBrush" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0" Color="#262623" />
            <GradientStop Offset="1" Color="#121210" />
          </LinearGradientBrush>
          <LinearGradientBrush x:Key="GlassPanelBrush" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0" Color="#26FFFFFF" />
            <GradientStop Offset="1" Color="#14FFFFFF" />
          </LinearGradientBrush>
          <LinearGradientBrush x:Key="GlassRimBrush" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0" Color="#59FFFFFF" />
            <GradientStop Offset="0.5" Color="#3A3A38" />
            <GradientStop Offset="1" Color="#333333" />
          </LinearGradientBrush>
          <BoxShadows x:Key="GlassShadow">0 3 14 0 #66000000</BoxShadows>

          <!-- Selected tab text: pure white in dark theme. -->
          <SolidColorBrush x:Key="TabItemHeaderForegroundSelected" Color="#FFFFFF" />
          <SolidColorBrush x:Key="TabItemHeaderForegroundSelectedPointerOver" Color="#FFFFFF" />
          <SolidColorBrush x:Key="TabItemHeaderForegroundSelectedPressed" Color="#FFFFFF" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme>
      <FluentTheme.Palettes>
        <ColorPaletteResources x:Key="Light" Accent="#C41230" />
        <ColorPaletteResources x:Key="Dark" Accent="#C24A62" />
      </FluentTheme.Palettes>
    </FluentTheme>
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="FontSize" Value="14" />
    </Style>
    <Style Selector="Control">
      <Setter Property="TextElement.FontFamily" Value="{StaticResource AppFontFamily}" />
      <Setter Property="TextElement.FontWeight" Value="Bold" />
      <Setter Property="TextElement.FontSize" Value="14" />
    </Style>
    <Style Selector="TemplatedControl">
      <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Border">
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Thumb">
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Button">
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="TabItem">
      <Setter Property="FontFamily" Value="{StaticResource TitleFontFamily}" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="6,4" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="TabItem:selected">
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style Selector="TabItem:selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="TextElement.FontWeight" Value="Bold" />
    </Style>
    <Style Selector="Button.TitleBarIconButton">
      <Setter Property="Width" Value="36" />
      <Setter Property="Height" Value="36" />
      <Setter Property="MinWidth" Value="36" />
      <Setter Property="MaxWidth" Value="36" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="MaxHeight" Value="36" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.TitleBarTextButton">
      <Setter Property="Height" Value="36" />
      <Setter Property="MinWidth" Value="124" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="MaxHeight" Value="36" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FontFamily" Value="{StaticResource TitleFontFamily}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.TitleBarIconButton Path">
      <Setter Property="Fill" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.TitleBarIconButton Ellipse">
      <Setter Property="Stroke" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.TitleBarIconButton Rectangle">
      <Setter Property="Fill" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.TitleBarCloseButton">
      <Setter Property="Background" Value="{DynamicResource ChromeAccentBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.TitleBarCloseButton Path">
      <Setter Property="Fill" Value="White" />
    </Style>
    <Style Selector="Button.RunIconButton">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="28" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.InlineComboIconButton">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="32" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="Button.RunIconButton:disabled">
      <Setter Property="Opacity" Value="0.55" />
    </Style>
    <Style Selector="Button.RunIconButton Path">
      <Setter Property="Fill" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.PrimaryRunIconButton">
      <Setter Property="Background" Value="{DynamicResource ChromeAccentBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.PrimaryRunIconButton Path">
      <Setter Property="Fill" Value="White" />
    </Style>
    <Style Selector="TextBlock.SectionHeader">
      <Setter Property="FontFamily" Value="{StaticResource TitleFontFamily}" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{DynamicResource ChromeAccentBrush}" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.StatusBar">
      <Setter Property="Background" Value="{DynamicResource GlassPanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource GlassRimBrush}" />
      <Setter Property="BorderThickness" Value="0,1,0,0" />
    </Style>
    <Style Selector="Border.StatusBar.status-warning">
      <Setter Property="Background" Value="{DynamicResource ChromeAccentBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChromeAccentBrush}" />
      <Setter Property="BorderThickness" Value="0,2,0,0" />
    </Style>
    <Style Selector="TextBlock.StatusBarReadout">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock.StatusBarReadout.position">
      <Setter Property="Foreground" Value="{DynamicResource ChromeAccentBrush}" />
    </Style>
    <Style Selector="Border.StatusBar.status-warning TextBlock.StatusBarReadout">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style Selector="Slider /template/ Thumb">
      <Setter Property="Width" Value="6" />
      <Setter Property="Height" Value="18" />
      <Setter Property="MinWidth" Value="6" />
      <Setter Property="MaxWidth" Value="6" />
      <Setter Property="MinHeight" Value="18" />
      <Setter Property="MaxHeight" Value="18" />
      <Setter Property="Background" Value="{DynamicResource ChromeAccentBrush}" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="0" />
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Slider /template/ Thumb /template/ Border">
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="CheckBox /template/ Border">
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="TextBlock">
      <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.PositionButton">
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.PositionButton.active">
      <Setter Property="Background" Value="{DynamicResource ChromeAccentBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.PositionButton.active > TextBlock">
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Border.SeqActiveRow">
      <!-- Neutral fill + a red left bar marks the active row WITHOUT reading as
           out-of-band (red is reserved for out-of-accept-band values). -->
      <Setter Property="Background" Value="{DynamicResource PanelBgBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChromeAccentBrush}" />
      <Setter Property="BorderThickness" Value="3,0,0,0" />
    </Style>
    <!--
      The reusable crystal pane: translucent frost fill, top-lit rim bevel, and a
      soft elevation shadow. Corners stay square via the global Border style. Apply
      `Classes="GlassCard"` to any chrome surface that should float above the backdrop.
    -->
    <Style Selector="Border.GlassCard">
      <Setter Property="Background" Value="{DynamicResource GlassPanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource GlassRimBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BoxShadow" Value="{DynamicResource GlassShadow}" />
    </Style>
    <Style Selector="Border.PositionPanel">
      <Setter Property="Background" Value="{DynamicResource GlassPanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource GlassRimBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BoxShadow" Value="{DynamicResource GlassShadow}" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Border.PositionResultPanel">
      <Setter Property="Background" Value="{DynamicResource GlassPanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource GlassRimBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BoxShadow" Value="{DynamicResource GlassShadow}" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Border.PositionResultGroup">
      <Setter Property="Background" Value="{DynamicResource GlassPanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource GlassRimBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BoxShadow" Value="{DynamicResource GlassShadow}" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Border.PositionResultGroup.primary">
      <Setter Property="BorderBrush" Value="{DynamicResource GlassRimBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.PositionResultBadge">
      <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Border.PositionResultBadge.ok">
      <Setter Property="Background" Value="{DynamicResource PanelBgBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource VarioGoodBrush}" />
    </Style>
    <Style Selector="Border.PositionResultBadge.warn">
      <Setter Property="Background" Value="{DynamicResource ChromeAccentBrush}" />
    </Style>
    <Style Selector="Border.PositionResultBadge.pending">
      <Setter Property="Background" Value="{DynamicResource ChromeBorderBrush}" />
    </Style>
    <Style Selector="Border.PositionResultBadge TextBlock">
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Border.PositionResultBadge.ok TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource VarioGoodBrush}" />
    </Style>
    <Style Selector="Border.PositionResultBadge.pending TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
  </Application.Styles>
</Application>
